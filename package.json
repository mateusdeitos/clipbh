{
  "name": "clipbh",
  "private": true,
  "version": "1.2.0",
  "type": "module",
  "main": "main.js",
  "author": "Mateus Campos Deitos (@mateusdeitos)",
  "description": "Clipboard History Manager",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mateusdeitos/clipbh"
  },
  "scripts": {
    "vite:dev": "vite",
    "vite:build": "vite build",
    "electron:dev": "electron .",
    "dev": "concurrently \"npm run vite:dev\" \"npm run electron:dev\"",
    "build": "npm run vite:build && electron-builder",
    "build:mac": "npm run vite:build && electron-builder --mac --publish never"
  },
  "build": {
    "appId": "com.mateusdeitos.clipbh",
    "productName": "ClipDB",
    "files": [
      "dist/**/*",
      "main.js",
      "preload.js",
      "node_modules/**/*",
      "!node_modules/.cache"
    ],
    "extraResources": [
      {
        "from": "node_modules/sql.js/dist/sql-wasm.wasm",
        "to": "."
      }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "entitlements.mac.plist",
      "entitlementsInherit": "entitlements.mac.plist",
      "target": [
        { "target": "dmg", "arch": ["arm64", "x64"] }
      ]
    },
    "dmg": {
      "contents": [
        { "x": 130, "y": 220 },
        { "x": 410, "y": 220, "type": "link", "path": "/Applications" }
      ],
      "window": { "width": 540, "height": 380 }
    },
    "publish": null
  },
  "dependencies": {
    "@tanstack/react-query": "^5.90.21",
    "lucide-react": "^0.454.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sql.js": "^1.12.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.0.1",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.19",
    "vite": "^5.4.10"
  }
}
